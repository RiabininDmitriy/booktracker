{
  "name": "booktracker",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:api": "pnpm --filter api dev",
    "dev:swagger": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm run --recursive build",
    "lint": "pnpm run --recursive lint",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,md}\" \"package.json\" \"pnpm-workspace.yaml\"",
    "typecheck": "pnpm run --recursive typecheck",
    "test": "pnpm run --recursive test",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "next": "16.1.6",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
