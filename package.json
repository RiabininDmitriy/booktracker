{
  "name": "booktracker",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:api": "pnpm --filter api dev",
    "dev:swagger": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:web:turbo": "pnpm --filter web dev:turbo",
    "dev:web:e2e": "pnpm --filter web dev:e2e",
    "build": "pnpm run --recursive build",
    "lint": "pnpm run --recursive lint",
    "lint:biome": "biome check apps/api/src",
    "format": "prettier --write \"apps/web/**/*.{ts,tsx,js,jsx,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"apps/web/**/*.{ts,tsx,js,jsx,json,md}\" \"package.json\" \"pnpm-workspace.yaml\"",
    "typecheck": "pnpm run --recursive typecheck",
    "test": "pnpm run --recursive test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "next": "16.1.5",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "wait-on": "^9.0.4"
  },
  "lint-staged": {
    "apps/api/**/*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ],
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
